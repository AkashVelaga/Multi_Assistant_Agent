{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "preferences": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Task": {
      "title": "Task",
      "description": "A productivity task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed", "failed"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "assignedTo": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "status"]
    },
    "History": {
      "title": "History",
      "description": "Historical record of agent interactions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "result": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["id", "userId", "action", "result", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "User tasks"
    },
    "/users/{userId}/history/{historyId}": {
      "schema": "History",
      "description": "User interaction history"
    }
  }
}
